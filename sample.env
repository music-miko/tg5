SUPPORT_CHANNEL=https://t.me/ArcUpdates
DEVS=
ENABLE_VPLAY=false
# Arc API media channel cache — set to your Telegram channel ID (e.g. -1001234567890)
MEDIA_CHANNEL_ID=
